{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "private-chess",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-05-23",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
    }
  },
  "secrets": {
    "required": [
      "MONGODB_URI",
      "MONGODB_DB",
      "AUTH_SESSION_SECRET"
    ]
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  }
}
